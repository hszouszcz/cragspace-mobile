{
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(npm:*)",
      "Bash(git:*)",
      "Bash(ls:*)"
    ],
    "deny": ["Read(.env)", "Read(.env.local)", "Read(*.key)", "Read(*.pem)"]
  },

  "env": {
    "NODE_ENV": "development",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1"
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/validate-a11y.js {{file_path}}",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-design-tokens.js {{file_path}}",
            "timeout": 3000
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/check-bundle-size.js",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/security-scan.js {{file_path}}",
            "timeout": 8000
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "npm run test:coverage -- --silent",
            "timeout": 30000
          }
        ]
      }
    ]
  },

  "model": "claude-sonnet-4-6"
}
